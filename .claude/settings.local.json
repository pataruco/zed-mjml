{
  "permissions": {
    "allow": [
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:zed.dev)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:crates.io)",
      "WebFetch(domain:docs.rs)",
      "WebFetch(domain:oxc.rs)",
      "WebFetch(domain:biomejs.dev)",
      "WebFetch(domain:documentation.mjml.io)",
      "Bash(cargo search mrml --limit 5)",
      "Bash(cargo fetch)",
      "Bash(cargo build)",
      "Bash(cargo test)",
      "Bash(cargo run)",
      "WebFetch(domain:)",
      "Bash(cargo test --manifest-path crates/mjml-lsp/Cargo.toml)",
      "Bash(cargo build --manifest-path crates/mjml-lsp/Cargo.toml)",
      "Bash(cargo clippy -- -D warnings)",
      "Bash(cargo clippy --manifest-path crates/mjml-lsp/Cargo.toml -- -D warnings)",
      "Bash(echo \"=== mrml version in use ===\" && grep -A0 'name = \"mrml\"' crates/mjml-lsp/Cargo.lock && echo \"=== render API in mrml docs \\(search local registry source\\) ===\" && find ~/.cargo -type d -name 'mrml-*' 2>/dev/null | head -3)"
    ]
  }
}
