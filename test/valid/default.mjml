<mjml>
  <mj-head>
    <mj-title>Welcome Email</mj-title>
    <mj-preview>Thanks for signing up!</mj-preview>
    <mj-attributes>
      <mj-all font-family="Helvetica, Arial, sans-serif" />
      <mj-class name="blue" color="#007bff" />
    </mj-attributes>
    <mj-style>
      .header { background-color: #f4f4f4; }
      .footer a { color: #888888; text-decoration: none; }
    </mj-style>
  </mj-head>
  <mj-body background-color="#ffffff">
    <mj-section css-class="header" padding="20px 0">
      <mj-column>
        <mj-image src="https://example.com/logo.png" alt="Logo" width="150px" />
      </mj-column>
    </mj-section>
    <mj-column>
      <mj-text font-size="24px" font-weight="bold" align="center">
        Welcome aboard!
      </mj-text>
      <mj-text font-size="16px" line-height="1.5" padding-top="10px">
        We're thrilled to have you. Here's what you can do next:
      </mj-text>
      <mj-button href="https://example.com/get-started" background-color="#007bff" border-radius="4px">
        Get Started
      </mj-button>
    </mj-column>
    <mj-section padding="20px">

    </mj-section>
    <mj-section padding="10px">
      <mj-column width="50%">
        <mj-image src="https://example.com/feature1.png" alt="Feature 1" />
        <mj-text align="center" font-size="14px">Organize your work</mj-text>
      </mj-column>
      <mj-column width="50%">
        <mj-image src="https://example.com/feature2.png" alt="Feature 2" />
        <mj-text align="center" font-size="14px">Collaborate with your team</mj-text>
      </mj-column>
    </mj-section>
    <mj-section>
      <mj-column>
        <mj-divider border-color="#eeeeee" />
        <mj-text font-size="12px" color="#888888" align="center">
          © 2026 Example Inc. All rights reserved.
        </mj-text>
        <mj-social font-size="12px" icon-size="20px" mode="horizontal" align="center">
          <mj-social-element name="twitter" href="https://twitter.com/example" />
          <mj-social-element name="github" href="https://github.com/example" />
        </mj-social>
      </mj-column>
    </mj-section>
  </mj-body>
</mjml>
