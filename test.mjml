<mjml>
  <mj-head>
    <mj-title>Test Email</mj-title>
    <mj-preview>Preview text visible in inbox</mj-preview>
    <mj-breakpoint width="600px" />
    <mj-attributes>
      <mj-all font-family="Arial, sans-serif" />
      <mj-class name="heading" font-size="24px" color="#333333" />
    </mj-attributes>
    <mj-font name="Roboto" href="https://fonts.googleapis.com/css?family=Roboto" />
    <mj-style>
      .blue { color: #007bff; }
      .container { background-color: #f4f4f4; }
      h1 { font-weight: bold; }
        </mj-style>
    <mj-html-attributes>
      <mj-selector path=".link">
        <mj-html-attribute name="data-tracking">true</mj-html-attribute>
      </mj-selector>
    </mj-html-attributes>
  </mj-head>

  <mj-body background-color="#ffffff">
    <!-- Hero Section -->
    <mj-hero mode="fixed" background-url="https://example.com/hero.jpg" background-color="#2f2936" padding="100px 0">
      <mj-text align="center" color="#ffffff" font-size="32px">
        Welcome to Our Newsletter
      </mj-text>
      <mj-button href="https://example.com" background-color="#007bff" color="#ffffff">
        Get Started
      </mj-button>
    </mj-hero>

    <!-- Main Content -->
    <mj-section background-color="#ffffff" padding="20px">
      <mj-column width="60%">
        <mj-text font-size="20px" color="#333333">
          Hello World &amp; Welcome!
        </mj-text>
        <mj-text>
          This is a test email template to verify MJML syntax highlighting.
        </mj-text>
        <mj-button href="https://example.com" background-color="#007bff" border-radius="4px">
          Click Me
        </mj-button>
      </mj-column>
      <mj-column width="40%">
        <mj-image src="https://example.com/image.jpg" alt="Example image" border-radius="8px" />
      </mj-column>
    </mj-section>

    <mj-section>
      <mj-column>
        <mj-divider border-color="#cccccc" border-width="1px" />
        <mj-spacer height="20px" />
      </mj-column>
    </mj-section>

    <!-- Accordion -->
    <mj-section>
      <mj-column>
        <mj-accordion>
          <mj-accordion-element>
            <mj-accordion-title>FAQ Item 1</mj-accordion-title>
            <mj-accordion-text>Answer to question 1</mj-accordion-text>
          </mj-accordion-element>
          <mj-accordion-element>
            <mj-accordion-title>FAQ Item 2</mj-accordion-title>
            <mj-accordion-text>Answer to question 2</mj-accordion-text>
          </mj-accordion-element>
        </mj-accordion>
      </mj-column>
    </mj-section>

    <!-- Navigation -->
    <mj-section>
      <mj-column>
        <mj-navbar>
          <mj-navbar-link href="https://example.com/home">Home</mj-navbar-link>
          <mj-navbar-link href="https://example.com/about">About</mj-navbar-link>
          <mj-navbar-link href="https://example.com/contact">Contact</mj-navbar-link>
        </mj-navbar>
      </mj-column>
    </mj-section>

    <!-- Carousel -->
    <mj-section>
      <mj-column>
        <mj-carousel>
          <mj-carousel-image src="https://example.com/slide1.jpg" alt="Slide 1" />
          <mj-carousel-image src="https://example.com/slide2.jpg" alt="Slide 2" />
          <mj-carousel-image src="https://example.com/slide3.jpg" alt="Slide 3" />
        </mj-carousel>
      </mj-column>
    </mj-section>

    <!-- Social & Footer -->
    <mj-section background-color="#f4f4f4">
      <mj-column>
        <mj-social font-size="12px" icon-size="24px" mode="horizontal">
          <mj-social-element name="facebook" href="https://facebook.com" />
          <mj-social-element name="twitter" href="https://twitter.com" />
          <mj-social-element name="linkedin" href="https://linkedin.com" />
        </mj-social>
        <mj-divider border-color="#dddddd" />
        <mj-text align="center" font-size="12px" color="#999999">
          &copy; 2026 Company Name. All rights reserved.
        </mj-text>
      </mj-column>
    </mj-section>

    <!-- Raw HTML passthrough -->
    <mj-section>
      <mj-column>
        <mj-raw>
          <div style="text-align: center;">Custom HTML content</div>
        </mj-raw>
      </mj-column>
    </mj-section>

    <!-- Table -->
    <mj-section>
      <mj-column>
        <mj-table>
          <tr>
            <th>Item</th>
            <th>Price</th>
          </tr>
          <tr>
            <td>Widget</td>
            <td>$9.99</td>
          </tr>
        </mj-table>
      </mj-column>
    </mj-section>

    <!-- Wrapper example -->
    <mj-wrapper background-color="#eeeeee" padding="20px">
      <mj-section>
        <mj-group>
          <mj-column>
            <mj-text>Column A</mj-text>
          </mj-column>
          <mj-column>
            <mj-text>Column B</mj-text>
          </mj-column>
        </mj-group>
      </mj-section>
    </mj-wrapper>
  </mj-body>
</mjml>
